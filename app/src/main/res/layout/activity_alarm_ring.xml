<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <TextView android:id="@+id/tvClock"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="72sp" android:textColor="#FFFFFF" android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.28" />

    <TextView android:id="@+id/tvLabel"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="22sp" android:textColor="#CCFFFFFF"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvClock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.chip.Chip android:id="@+id/chipStation"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        app:chipBackgroundColor="#441A73E8"
        app:chipIcon="@drawable/ic_radio"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSnooze"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="140dp" android:layout_height="60dp"
        android:text="Snooze" app:strokeColor="#FFFFFF" android:textColor="#FFFFFF"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnDismiss"
        app:layout_constraintHorizontal_chainStyle="spread" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDismiss"
        android:layout_width="140dp" android:layout_height="60dp"
        android:text="Dismiss" app:backgroundTint="#1A73E8"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnSnooze"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
